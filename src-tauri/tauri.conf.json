{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "USB Vault",
	"version": "1.0.0",
	"identifier": "com.rogergomez.usbvault",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"security": {
			"csp": null,
			"assetProtocol": {
				"enable": true,
				"scope": [
					"**"
				]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"icon": [
			"../public/icon.png"
		],
		"windows": {
			"nsis": {
				"installMode": "currentUser"
			}
		}
	}
}